# Copy to `.env` for local tools that read it; Flask loads these if you export them.

# Session / signing (required in any shared deployment)
# FIELDSENSE_SECRET_KEY=
# (Legacy typo still read: FIELDENSE_SECRET_KEY)
# FIELDSENSE_SECURE_COOKIE=1

# SQLite path (default: app folder). Vercel uses /tmp — see api/index.py
# FIELDSENSE_DB_PATH=

# Leaf image uploads (default: app/uploads). Vercel uses /tmp
# FIELDSENSE_UPLOAD_DIR=

# Server port when running `python app.py` from ./app
# PORT=5050
